<?xml version="1.0" encoding="utf-8"?>
<!--
    item_chat_ai.xml
    Left-aligned light bubble — AI messages.
    Small avatar icon sits to the left of the bubble.
    Max width: 78% of parent.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="48dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- AI avatar -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_avatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_ai_avatar"
        android:scaleType="centerCrop"
        android:contentDescription="AI"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.AIFoodApp.Pill"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bubble -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#F1F3F4"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="@id/iv_avatar"
        app:layout_constraintStart_toEndOf="@id/iv_avatar"
        app:layout_constrainedWidth="true"
        app:layout_constraintWidth_percent="0.78">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <!-- "Food AI" label -->
            <TextView
                android:id="@+id/tv_sender_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food AI"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#212121"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="sans-serif"
                tools:text="A typical Vietnamese pho has around 350–500 kcal depending on portion size and toppings. It's high in protein and relatively low in fat." />

            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#9E9E9E"
                android:textSize="10sp"
                tools:text="2:31 PM" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>