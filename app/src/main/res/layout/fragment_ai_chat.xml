<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- Quick suggestion chips -->
    <HorizontalScrollView
        android:id="@+id/hsv_suggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_suggest"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🍳 Suggest recipe"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/brand_primary"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_calories"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:text="🔥 Calories"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/brand_primary"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_quick_meal"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:text="⚡ Quick meals"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/brand_primary"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_nutrition"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:text="🥗 Nutrition tips"
                style="@style/Widget.MaterialComponents.Chip.Action"
                app:chipBackgroundColor="@color/white"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/brand_primary"
                android:textSize="12sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:overScrollMode="never"
        app:stackFromEnd="true"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/hsv_suggestions"
        app:layout_constraintBottom_toTopOf="@id/layout_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Typing indicator -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_typing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="1dp"
        app:strokeColor="@color/bg_divider"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/layout_input"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="●  ●  ●"
            android:textColor="@color/text_hint"
            android:textSize="10sp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Input area -->
    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask about food…"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="22dp"
            app:boxCornerRadiusTopEnd="22dp"
            app:boxCornerRadiusBottomStart="22dp"
            app:boxCornerRadiusBottomEnd="22dp"
            app:boxStrokeColor="@color/bg_divider"
            app:boxStrokeWidth="1dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="3"
                android:imeOptions="actionSend"
                android:textColor="#212121"
                android:textSize="14sp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/white"
            app:iconSize="18dp"
            app:iconPadding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="22dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>