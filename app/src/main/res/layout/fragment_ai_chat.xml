<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ── Toolbar ───────────────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_ai_avatar"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.AIFoodApp.Pill" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food AI"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/text_primary" />

                <!-- tv_status → binding: tvStatus -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to help"
                    android:textSize="11sp"
                    android:textColor="#4CAF50" />

            </LinearLayout>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- ── Empty state ────────────────────────────────────────────────────── -->
    <!-- layout_empty → binding: layoutEmpty -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layout_suggestions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/iv_empty_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_ai_avatar"
            android:alpha="0.85"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Ask me anything about food 🍜"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Recipes · Nutrition · Cooking tips"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:gravity="center" />

    </LinearLayout>

    <!-- ── Messages RecyclerView ──────────────────────────────────────────── -->
    <!-- rv_chat → binding: rvChat -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone"
        app:stackFromEnd="true"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/card_typing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_chat_ai"
        tools:itemCount="4"
        tools:visibility="visible" />

    <!-- ✅ FIX: card_typing THÊM MỚI → binding: cardTyping              -->
    <!-- Đây là lý do lỗi "Unresolved reference 'cardTyping'"             -->
    <!-- Hiển thị "AI đang gõ…" animation khi chờ phản hồi              -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_typing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="6dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_suggestions"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <!-- 3 chấm nhảy — dùng ProgressBar tạm hoặc thay bằng Lottie -->
            <ProgressBar
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/brand_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="AI is thinking…"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Suggestion chips ───────────────────────────────────────────────── -->
    <!-- layout_suggestions → binding: layoutSuggestions                     -->
    <HorizontalScrollView
        android:id="@+id/layout_suggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:background="@color/bg_screen"
        app:layout_constraintBottom_toTopOf="@id/divider_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/chip_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- chip_suggest → binding: chipSuggest -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_suggest"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🍳 Suggest recipe"
                android:textSize="12sp"
                android:textColor="@color/brand_primary"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <!-- chip_calories → binding: chipCalories -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_calories"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🔥 Calories"
                android:textSize="12sp"
                android:textColor="@color/brand_primary"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <!-- chip_quick → binding: chipQuick -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_quick"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="⚡ Quick meals"
                android:textSize="12sp"
                android:textColor="@color/brand_primary"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <!-- chip_nutrition → binding: chipNutrition -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_nutrition"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🥗 Nutrition"
                android:textSize="12sp"
                android:textColor="@color/brand_primary"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="@color/brand_primary"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Divider ─────────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider_input"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintBottom_toTopOf="@id/layout_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Input area ─────────────────────────────────────────────────────── -->
    <!-- layout_input → binding: layoutInput                                  -->
    <LinearLayout
        android:id="@+id/layout_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- til_message → binding: tilMessage -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask about food…"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/text_hint"
            app:boxBackgroundColor="@color/white">

            <!-- et_message → binding: etMessage -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:minLines="1"
                android:imeOptions="actionSend"
                android:textColor="#212121"
                android:textColorHint="#9E9E9E"
                android:textSize="15sp"
                android:background="@null"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- btn_send → binding: btnSend -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/white"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="23dp"
            android:stateListAnimator="@null"
            app:elevation="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>