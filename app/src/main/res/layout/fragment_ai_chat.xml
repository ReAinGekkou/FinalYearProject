<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_ai_chat.xml
    ─────────────────────────────────────────────────────────────────────
    SINGLE source of truth for both AiChatFragment AND CommunityChatFragment.
    Both fragments inflate this same layout.

    ALL IDs that code references are declared here:
      rvChat, etMessage, btnSend, tvStatus,
      layoutEmpty, layoutSuggestions (= hsvSuggestions),
      cardTyping, chipSuggest, chipCalories, chipQuick, chipNutrition
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- ── Toolbar ───────────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_ai_avatar"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.AIFoodApp.Pill"
                android:contentDescription="AI" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_toolbar_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food AI"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#212121" />

                <!-- tvStatus: "Ready to help" / "Thinking…" -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to help"
                    android:textSize="11sp"
                    android:textColor="#4CAF50"
                    tools:text="Ready to help" />

            </LinearLayout>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- ── Empty state ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutSuggestions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_ai_avatar"
            android:alpha="0.8"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ask me anything about food 🍜"
            android:textSize="17sp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#212121"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Recipes · Nutrition · Cooking tips"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:gravity="center" />

    </LinearLayout>

    <!-- ── Messages RecyclerView ──────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone"
        app:stackFromEnd="true"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/cardTyping"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_chat_ai"
        tools:visibility="visible" />

    <!-- ── Typing indicator ───────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone"
        app:cardCornerRadius="18dp"
        app:cardBackgroundColor="#F1F3F4"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutSuggestions"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot"
                android:layout_marginEnd="5dp" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot"
                android:layout_marginEnd="5dp" />

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_typing_dot" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ── Suggestion chips (hsvSuggestions = this view's old alias) ─── -->
    <HorizontalScrollView
        android:id="@+id/layoutSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:background="#F8F9FA"
        app:layout_constraintBottom_toTopOf="@id/dividerInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggest"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🍳 Suggest recipe"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="#2E7D32"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCalories"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🔥 Calories"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="#2E7D32"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipQuickMeal"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="⚡ Quick meals"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="#2E7D32"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNutrition"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="🥗 Nutrition"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                app:chipBackgroundColor="#E8F5E9"
                app:chipStrokeColor="#2E7D32"
                app:chipStrokeWidth="1dp"
                app:chipCornerRadius="17dp"
                app:chipMinHeight="34dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ── Divider ────────────────────────────────────────────────────── -->
    <View
        android:id="@+id/dividerInput"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Input row ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask about food…"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="#9E9E9E"
            app:boxBackgroundColor="@color/white">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="4"
                android:minLines="1"
                android:imeOptions="actionSend"
                android:textColor="#212121"
                android:textColorHint="#9E9E9E"
                android:textSize="15sp"
                android:background="@null"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="9dp"
            android:padding="15dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:icon="@drawable/ic_send"
            app:iconTint="@color/white"
            app:iconSize="20dp"
            app:iconPadding="0dp"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="23dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>