<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml
    ─────────────────────────────────────────────────────────────────────────
    Home screen — CoordinatorLayout enables collapsing app bar behaviour.
    RecyclerView uses smooth scroll + clipToPadding=false for edge cards.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ── App bar ──────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_screen"
        android:elevation="0dp"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/rv_recipes">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/greeting_default"
                android:textAppearance="@style/TextAppearance.AIFoodApp.Body2"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar"
                tools:text="Good morning 👋" />

            <!-- Screen title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/home_title"
                android:textAppearance="@style/TextAppearance.AIFoodApp.H2"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar"
                tools:text="Discover Recipes" />

            <!-- User avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/sym_def_app_icon"
                android:scaleType="centerCrop"
                android:contentDescription="@string/cd_user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.AIFoodApp.Pill"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Search bar -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_search"
                style="@style/Widget.AIFoodApp.SearchInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="@string/hint_search"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="@color/text_hint"
                app:endIconDrawable="@drawable/ic_filter"
                app:endIconTint="@color/brand_primary"
                app:layout_constraintTop_toBottomOf="@id/tv_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:textAppearance="@style/TextAppearance.AIFoodApp.Body1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category chips -->
            <HorizontalScrollView
                android:id="@+id/hsv_categories"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/til_search"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <!-- Chips are inflated programmatically in HomeFragment -->
                    <!-- Example chip for preview: -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/category_all"
                        android:checked="true"
                        app:chipBackgroundColor="@color/selector_chip_bg"
                        app:chipStrokeColor="@color/brand_primary"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"
                        android:textColor="@color/selector_chip_text"
                        tools:ignore="HardcodedText" />

                </com.google.android.material.chip.ChipGroup>

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Main content ─────────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Section: Featured -->
            <TextView
                android:id="@+id/tv_featured_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/label_featured"
                android:textAppearance="@style/TextAppearance.AIFoodApp.H3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Horizontal featured recipes -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_featured"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:overScrollMode="never"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tv_featured_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:listitem="@layout/item_recipe_featured"
                tools:itemCount="3" />

            <!-- Section: All Recipes label -->
            <TextView
                android:id="@+id/tv_recipes_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/label_all_recipes"
                android:textAppearance="@style/TextAppearance.AIFoodApp.H3"
                app:layout_constraintTop_toBottomOf="@id/rv_featured"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_see_all" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_see_all"
                style="@style/Widget.AIFoodApp.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_see_all"
                android:textSize="13sp"
                app:layout_constraintTop_toTopOf="@id/tv_recipes_label"
                app:layout_constraintBottom_toBottomOf="@id/tv_recipes_label"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Main recipe list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recipes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="88dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/tv_recipes_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_recipe_card"
                tools:itemCount="5" />

            <!-- Empty state -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_empty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tv_recipes_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="gone">

                <ImageView
                    android:id="@+id/iv_empty"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@android:drawable/ic_menu_report_image"
                    android:alpha="0.5"
                    android:contentDescription="@string/cd_no_recipes"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/empty_recipes_title"
                    android:textAppearance="@style/TextAppearance.AIFoodApp.H3"
                    android:textColor="@color/text_secondary"
                    app:layout_constraintTop_toBottomOf="@id/iv_empty"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_empty_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/empty_recipes_sub"
                    android:textAppearance="@style/TextAppearance.AIFoodApp.Body2"
                    android:gravity="center"
                    android:paddingHorizontal="32dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_empty_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Load more indicator -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_load_more"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:indicatorColor="@color/brand_primary"
                app:trackColor="@color/bg_divider"
                app:layout_constraintTop_toBottomOf="@id/rv_recipes"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ── FAB: AI Assistant ─────────────────────────────────────────────── -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_ai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/fab_ai"
        android:textColor="@color/white"
        app:icon="@drawable/ic_ai_chat"
        app:iconTint="@color/white"
        app:backgroundTint="@color/brand_primary"
        app:elevation="4dp"
        app:shapeAppearance="@style/ShapeAppearance.AIFoodApp.Pill" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>